# Auth.js
AUTH_SECRET=your-auth-secret-min-32-chars
AUTH_URL=http://localhost:3000

# Google OAuth
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/ntik-marketplace

# ─── Storage Provider ─────────────────────────────────────────────────────────
# Set to "cloudinary" (default) or "gcs"
STORAGE_PROVIDER=cloudinary

# Cloudinary (active when STORAGE_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Google Cloud Storage (active when STORAGE_PROVIDER=gcs)
GCS_BUCKET_NAME=ntik-media-vault
GCS_PROJECT_ID=your-gcs-project-id
GCS_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GCS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
NEXT_PUBLIC_GCS_BUCKET_URL=https://storage.googleapis.com/ntik-media-vault
# ──────────────────────────────────────────────────────────────────────────────

# Public
NEXT_PUBLIC_WHATSAPP_NUMBER=+919876543210
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=NTIK Heritage Marketplace

# Admin (comma-separated Gmail addresses that get admin role)
ADMIN_EMAILS=your-admin@gmail.com

# Email (Resend) — used for password reset emails. Sign up free at https://resend.com
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=NTIK Heritage <onboarding@resend.dev>
