# =============================================================================
# NTIK Heritage — Environment Variables
# Copy this file to .env.local for local development.
# For Render/Vercel: add these as Environment Variables in the dashboard.
# =============================================================================

# ─── Auth.js ──────────────────────────────────────────────────────────────────
# Generate AUTH_SECRET: openssl rand -hex 32
AUTH_SECRET=your-auth-secret-min-32-chars

# AUTH_URL / NEXTAUTH_URL — trustHost:true means this is AUTO-DETECTED in production.
# Only set this locally if the detected URL is wrong (e.g. you use a tunnel).
# Do NOT set AUTH_URL on Render or Vercel — let the host header take over.
# AUTH_URL=http://localhost:3000

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# Console: https://console.cloud.google.com/apis/credentials
# Authorised redirect URIs must include:
#   http://localhost:3000/api/auth/callback/google              (local)
#   https://ntik-2hwf.onrender.com/api/auth/callback/google    (Render)
#   https://yourdomain.com/api/auth/callback/google             (production)
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/ntik-marketplace

# ─── Storage Provider ─────────────────────────────────────────────────────────
# Set to "cloudinary" (default) or "gcs"
STORAGE_PROVIDER=cloudinary

# Cloudinary (active when STORAGE_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Google Cloud Storage (active when STORAGE_PROVIDER=gcs)
GCS_BUCKET_NAME=ntik-media-vault
GCS_PROJECT_ID=your-gcs-project-id
GCS_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GCS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
NEXT_PUBLIC_GCS_BUCKET_URL=https://storage.googleapis.com/ntik-media-vault

# ─── Public URLs ──────────────────────────────────────────────────────────────
# CRITICAL: Set NEXT_PUBLIC_SITE_URL to your real domain in production.
# This drives: password reset email links, OG/Twitter metadata, sitemap, robots.txt
#
#   Local dev:    http://localhost:3000
#   Render:       https://ntik-2hwf.onrender.com
#   Custom domain (future): https://yourdomain.com
#
# Set this in Render dashboard → Environment → NEXT_PUBLIC_SITE_URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=NTIK Heritage Marketplace
NEXT_PUBLIC_WHATSAPP_NUMBER=+919876543210

# ─── Admin ────────────────────────────────────────────────────────────────────
# Comma-separated email addresses that receive the "admin" role on sign-in
ADMIN_EMAILS=your-admin@gmail.com

# ─── Email — Resend ────────────────────────────────────────────────────────────
# Sign up free at https://resend.com (3,000 emails/month free)
# For testing without a verified domain use onboarding@resend.dev as the FROM address
# (emails will only deliver to the Resend account owner's email in sandbox mode)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=NTIK Heritage <onboarding@resend.dev>

# ─── Windows / Node.js 22 only ────────────────────────────────────────────────
# Required on Windows with Node 22 to fix MongoDB Atlas SSL handshake errors.
# Remove this line on Linux (Render) — it is not needed there.
# NODE_OPTIONS=--tls-min-v1.0
