# Force sharp to download the correct native binary for the current platform.
# Without this, a Windows-installed node_modules won't have the Linux binary
# that Render needs, causing "Could not load the "sharp" module" errors.
sharp_binary_host=https://npmmirror.com/mirrors/sharp
sharp_libvips_binary_host=https://npmmirror.com/mirrors/sharp-libvips
